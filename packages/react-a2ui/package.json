{
  "name": "@assistant-ui/react-a2ui",
  "version": "0.0.1",
  "description": "A2UI (Agent-to-UI) declarative rendering integration for assistant-ui",
  "keywords": [
    "a2ui",
    "agent-to-ui",
    "assistant-ui",
    "react",
    "ai",
    "declarative-ui"
  ],
  "author": "AgentbaseAI Inc.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ag-ui": {
      "types": "./dist/bridge/ag-ui-bridge.d.ts",
      "default": "./dist/bridge/ag-ui-bridge.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "aui-build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@assistant-ui/core": "^0.1.13"
  },
  "peerDependencies": {
    "@types/react": "*",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@assistant-ui/x-buildutils": "workspace:*",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://www.assistant-ui.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistant-ui/assistant-ui.git",
    "directory": "packages/react-a2ui"
  },
  "bugs": {
    "url": "https://github.com/assistant-ui/assistant-ui/issues"
  }
}
